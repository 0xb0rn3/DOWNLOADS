def get_urls_interactive():
    print(clr("\n  📋 Enter URLs / magnet links (one per line).", W))
    print(clr("     HTTP, HTTPS, FTP, .torrent URLs, magnet: links all supported.", DIM))
    print(clr("     Type 'done' or press Enter on empty line to start.\n", DIM))
    urls = []
    while True:
        raw = input(clr(f"  [{len(urls)+1}] URL → ", B)).strip()
        if raw.lower() in ("done", "") and urls:
            break
        elif raw.lower() in ("done", ""):
            if not urls:
                print(clr("  ⚠  Please enter at least one URL.", Y))
            continue
        else:
            urls.append(raw)
            print(clr(f"     ✓ Added", G))
    return urls


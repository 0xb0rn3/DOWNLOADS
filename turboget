# ── Utility ───────────────────────────────────────────────────────────────────
def human_size(b):
    for u in ["B","KB","MB","GB","TB"]:
        if b < 1024: return f"{b:.1f} {u}"
        b /= 1024
    return f"{b:.1f} PB"

def human_speed(bps):
    return f"{human_size(bps)}/s"

def check_tool(name):
    return shutil.which(name) is not None

def ask_directory():
    print(clr("\n📁 Where should files be downloaded?", Y))
    print(clr(f"   [Press Enter for current dir: {os.getcwd()}]", DIM))
    raw = input(clr("   Directory → ", B)).strip()
    path = Path(raw) if raw else Path.cwd()
    if not path.exists():
        yn = input(clr(f"   {path} doesn't exist. Create it? [Y/n] ", Y)).strip().lower()
        if yn in ("", "y"):
            path.mkdir(parents=True)
            print(clr(f"   ✓ Created {path}", G))
        else:
            print(clr("   ✗ Aborted.", R)); sys.exit(1)
    return str(path.resolve())

def is_magnet(url):
    return url.startswith("magnet:")

def is_torrent_file(url):
    return url.lower().endswith(".torrent")

def is_torrent(url):
    return is_magnet(url) or is_torrent_file(url)

# ── Progress bar (pure Python, no deps) ──────────────────────────────────────
class ProgressBar:
    def __init__(self, total=None, label=""):
        self.total = total
        self.label = label
        self.done  = 0
        self.start = time.time()
        self._lock = threading.Lock()

    def update(self, chunk):
        with self._lock:
            self.done += chunk
            self._draw()

    def _draw(self):
        elapsed = max(time.time() - self.start, 0.001)
        speed   = self.done / elapsed
        cols    = shutil.get_terminal_size((80,20)).columns
        if self.total:
            pct  = min(self.done / self.total, 1.0)
            bar_w = max(cols - 60, 10)
            filled = int(bar_w * pct)
            bar  = clr("█" * filled, G) + clr("░" * (bar_w - filled), DIM)
            line = (f"\r  {clr(self.label[:20],'W')} [{bar}] "
                    f"{clr(f'{pct*100:.1f}%',Y)} "
                    f"{clr(human_size(self.done),'C')}/{clr(human_size(self.total),'C')} "
                    f"{clr(human_speed(speed),M)}")
        else:
            spinner = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"[int(elapsed*8) % 10]
            line = (f"\r  {clr(spinner, Y)} {clr(self.label[:30],'W')}  "
                    f"{clr(human_size(self.done),'C')}  {clr(human_speed(speed),M)}")
        print(line, end="", flush=True)

    def finish(self):
        self._draw()
        elapsed = max(time.time() - self.start, 0.001)
        avg = self.done / elapsed
        print(f"  {clr('✓ Done','G')}  "
              f"{clr(human_size(self.done),'C')} in "
              f"{clr(f'{elapsed:.1f}s','Y')} avg "
              f"{clr(human_speed(avg),M)}")

# ── Downloader backends ───────────────────────────────────────────────────────

def download_with_aria2c(url, dest_dir, connections=16):
    """aria2c: fastest possible, supports HTTP/FTP/BitTorrent/Magnet"""
    cmd = [
        "aria2c",
        "--dir", dest_dir,
        "--max-connection-per-server", str(connections),
        "--split", str(connections),
        "--min-split-size", "1M",
        "--max-concurrent-downloads", "5",
        "--continue=true",
        "--auto-file-renaming=false",
        "--console-log-level=warn",
        "--summary-interval=1",
    ]
    if is_torrent(url):
        cmd += ["--seed-time=0"]  # download only, no seeding
    cmd.append(url)
    print(clr(f"\n  ⚡ aria2c → {url[:70]}…", C))
    proc = subprocess.run(cmd, cwd=dest_dir)
    return proc.returncode == 0

def download_with_wget(url, dest_dir):
    """wget fallback"""
    cmd = ["wget", "--continue", "--show-progress",
           "--progress=bar:force", "-P", dest_dir, url]
    print(clr(f"\n  ⬇  wget → {url[:70]}…", C))
    proc = subprocess.run(cmd)
    return proc.returncode == 0

def download_with_curl(url, dest_dir):
    """curl fallback"""
    fname = os.path.basename(urllib.parse.urlparse(url).path) or "download"
    out   = os.path.join(dest_dir, fname)
    cmd   = ["curl", "-L", "--continue-at", "-", "-#", "-o", out, url]
    print(clr(f"\n  ⬇  curl → {url[:70]}…", C))
    proc = subprocess.run(cmd)
    return proc.returncode == 0

def download_pure_python(url, dest_dir):
    """Pure Python multi-chunk downloader (no external tools needed)"""
    parsed = urllib.parse.urlparse(url)
    fname  = os.path.basename(parsed.path) or "download"
    fname  = urllib.parse.unquote(fname)
    outpath = os.path.join(dest_dir, fname)

    print(clr(f"\n  🐍 Python downloader → {url[:70]}…", C))

    req = urllib.request.Request(url, headers={"User-Agent":"TurboGet/1.0"})
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            total = int(resp.headers.get("Content-Length", 0)) or None
            pb = ProgressBar(total=total, label=fname)
            with open(outpath, "wb") as f:
                while True:
                    chunk = resp.read(1 << 17)  # 128 KB chunks
                    if not chunk: break
                    f.write(chunk)
                    pb.update(len(chunk))
            pb.finish()
    except Exception as e:
        print(clr(f"\n  ✗ Error: {e}", R))
        return False
    return True

def handle_torrent_no_aria2c(url, dest_dir):
    """Try libtorrent (python-libtorrent) for torrent/magnet if aria2c missing"""
    try:
        import libtorrent as lt
    except ImportError:
        print(clr("\n  ✗ Neither aria2c nor python-libtorrent found.", R))
        print(clr("    Install: sudo apt install aria2  OR  pip install lbry-libtorrent", Y))
        return False

    ses = lt.session()
    ses.listen_on(6881, 6891)
    params = {"save_path": dest_dir, "storage_mode": lt.storage_mode_t.storage_mode_sparse}

    if is_magnet(url):
        print(clr(f"\n  🧲 Magnet → {url[:70]}…", M))
        handle = lt.add_magnet_uri(ses, url, params)
        print(clr("  ⏳ Fetching metadata…", Y))
        while not handle.has_metadata():
            time.sleep(1)
        print(clr("  ✓ Metadata received", G))
    else:
        info   = lt.torrent_info(url)
        handle = ses.add_torrent({"ti": info, **params})

    print(clr("  ⚡ Downloading…\n", C))
    while not handle.is_seed():
        s = handle.status()
        pb_str = "█" * int(s.progress * 40) + "░" * (40 - int(s.progress * 40))
        print(f"\r  [{clr(pb_str, G)}] {clr(f'{s.progress*100:.1f}%',Y)} "
              f"↓{clr(human_speed(s.download_rate),M)} "
              f"peers:{clr(str(s.num_peers),C)}", end="", flush=True)
        time.sleep(1)
    print(clr("\n  ✓ Torrent complete!", G))
    return True

# ── Main downloader logic ─────────────────────────────────────────────────────

def pick_backend_and_download(url, dest_dir):
    torrent = is_torrent(url)

    if check_tool("aria2c"):
        ok = download_with_aria2c(url, dest_dir)
    elif torrent:
        ok = handle_torrent_no_aria2c(url, dest_dir)
    elif check_tool("wget"):
        ok = download_with_wget(url, dest_dir)
    elif check_tool("curl"):
        ok = download_with_curl(url, dest_dir)
    else:
        if torrent:
            ok = handle_torrent_no_aria2c(url, dest_dir)
        else:
            ok = download_pure_python(url, dest_dir)
    return ok


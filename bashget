#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════╗
# ║  BASHGET ⚡ PURE BASH · KERNEL-LEVEL SPEED                     ║
# ╚══════════════════════════════════════════════════════════════════╝
# Usage: ./bashget.sh [URL ...] or interactive mode
# Needs: curl  |  aria2c (recommended)  |  pv (optional)
#        transmission-cli or rtorrent (torrents without aria2c)

set -euo pipefail

R=$'\e[91m'; G=$'\e[92m'; Y=$'\e[93m'; B=$'\e[94m'
M=$'\e[95m'; C=$'\e[96m'; W=$'\e[97m'; DIM=$'\e[2m'
BOLD=$'\e[1m'; RST=$'\e[0m'

# ── Config (tune these) ───────────────────────────────────────────
PARALLEL_CHUNKS=16                 # Range-request chunks per file
CHUNK_MIN_SIZE=$(( 2*1024*1024 ))  # 2 MB min chunk
PARALLEL_FILES=4                   # Concurrent file downloads

CURL_OPTS=(
  --silent --show-error --location
  --retry 5 --retry-delay 1 --retry-max-time 30
  --connect-timeout 10 --keepalive-time 30
  --tcp-fastopen                   # Linux kernel TCP Fast Open
  --compressed
  --buffer-size 524288             # 512 KB kernel socket buffer
  -H "User-Agent: BashGet/2.0"
  -H "Connection: keep-alive"
)
WGET_OPTS=(
  --continue --retry-connrefused --waitretry=2
  --tries=5 --timeout=15 --progress=dot:mega
)

# ── /dev/shm = RAM disk → zero disk I/O until final splice ────────
[[ -d /dev/shm ]] && TMPBASE=/dev/shm/bashget_$$ || TMPBASE=/tmp/bashget_$$
mkdir -p "$TMPBASE"
trap 'rm -rf "$TMPBASE"' EXIT INT TERM

# ── Helpers ───────────────────────────────────────────────────────
die()  { printf "${R}  ✗ %s${RST}\n" "$*" >&2; exit 1; }
info() { printf "${C}  %s${RST}\n" "$*"; }
ok()   { printf "${G}  ✓ %s${RST}\n" "$*"; }
warn() { printf "${Y}  ⚠ %s${RST}\n" "$*"; }
has()  { command -v "$1" &>/dev/null; }

human_size() {
  local b=${1//[^0-9]/}; b=${b:-0}
  if   (( b >= 1073741824 )); then awk "BEGIN{printf \"%.2f GB\",$b/1073741824}"
  elif (( b >= 1048576    )); then awk "BEGIN{printf \"%.2f MB\",$b/1048576}"
  elif (( b >= 1024       )); then awk "BEGIN{printf \"%.2f KB\",$b/1024}"
  else printf "%d B" "$b"; fi
}
elapsed_since() { echo $(( $(date +%s) - ${1:-0} )); }

# ── Banner ────────────────────────────────────────────────────────
banner() {
  clear
  printf "${C}${BOLD}"
  printf '  ██████╗  █████╗ ███████╗██╗  ██╗ ██████╗ ███████╗████████╗\n'
  printf '  ██╔══██╗██╔══██╗██╔════╝██║  ██║██╔════╝ ██╔════╝╚══██╔══╝\n'
  printf '  ██████╔╝███████║███████╗███████║██║  ███╗█████╗     ██║   \n'
  printf '  ██╔══██╗██╔══██║╚════██║██╔══██║██║   ██║██╔══╝     ██║   \n'
  printf '  ██████╔╝██║  ██║███████║██║  ██║╚██████╔╝███████╗   ██║   \n'
  printf '  ╚═════╝ ╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝ ╚═════╝ ╚══════╝   ╚═╝  \n'
  printf "${RST}${Y}${BOLD}        ⚡ PURE BASH · KERNEL-LEVEL SPEED ⚡${RST}\n"
  printf "${DIM}   Parallel chunks · /dev/shm RAM staging · Direct syscalls${RST}\n\n"
}

# ── Tool detection ────────────────────────────────────────────────
detect_tools() {
  printf "${Y}  🔧 Backends:${RST}\n"
  local tools=(
    "curl:⚡ Primary – parallel byte-range chunks"
    "wget:✓  Fallback – streaming"
    "aria2c:🔥 Turbo – multi-source + torrent/magnet"
    "transmission-cli:🧲 Torrent fallback"
    "rtorrent:🧲 Torrent alt"
    "pv:📊 Pipe progress meter"
  )
  for entry in "${tools[@]}"; do
    local t="${entry%%:*}" d="${entry#*:}"
    if has "$t"; then printf "    ${G}✓${RST} ${W}%-22s${RST}${DIM}%s${RST}\n" "$t" "$d"
    else              printf "    ${DIM}✗ %s${RST}\n" "$t"; fi
  done; echo
}

# ── Directory prompt ──────────────────────────────────────────────
ask_directory() {
  printf "${Y}  📁 Download directory?${RST}\n${DIM}  [Enter = %s]${RST}\n" "$PWD"
  read -rp $'  \e[94m  Dir → \e[0m' DEST_DIR
  DEST_DIR="${DEST_DIR:-$PWD}"
  DEST_DIR="${DEST_DIR/#\~/$HOME}"
  if [[ ! -d "$DEST_DIR" ]]; then
    read -rp "$(printf '  \e[93m  Create "%s"? [Y/n] \e[0m' "$DEST_DIR")" yn
    [[ "${yn,,}" =~ ^(y|)$ ]] || die "Aborted."
    mkdir -p "$DEST_DIR"; ok "Created $DEST_DIR"
  fi
  DEST_DIR="$(realpath "$DEST_DIR")"
  ok "Saving to: ${BOLD}${DEST_DIR}${RST}"
}

# ── HTTP probing ──────────────────────────────────────────────────
get_file_size() {
  curl --silent --head --location --connect-timeout 10 \
       -H "User-Agent: BashGet/2.0" "$1" 2>/dev/null \
  | grep -i '^content-length:' | tail -1 \
  | awk '{print $2}' | tr -d '\r' || echo 0
}

supports_ranges() {
  curl --silent --head --location --connect-timeout 10 \
       -H "User-Agent: BashGet/2.0" "$1" 2>/dev/null \
  | grep -qi "accept-ranges: bytes"
}

get_filename_from_url() {
  local fname
  fname=$(curl --silent --head --location -H "User-Agent: BashGet/2.0" "$1" 2>/dev/null \
          | grep -i 'content-disposition' \
          | grep -oP 'filename[^;=\n]*=[\s"]*\K[^";\n]+' \
          | head -1 | tr -d '\r' || true)
  [[ -n "$fname" ]] && { echo "$fname"; return; }
  fname=$(basename "$(echo "$1" | cut -d? -f1)")
  echo "${fname:-download_$(date +%s)}"
}

# ── Live progress (background subshell polls chunk sizes) ─────────
_progress_watcher() {
  local tmpdir=$1 total=$2; shift 2; local pids=("$@")
  local cols; cols=$(tput cols 2>/dev/null || echo 80)
  local bw=$(( cols - 54 )); (( bw < 6 )) && bw=6
  local t0; t0=$(date +%s)
  while true; do
    local db=0
    for f in "$tmpdir"/part_* 2>/dev/null; do
      [[ -f "$f" ]] && { local s; s=$(stat -c%s "$f" 2>/dev/null||echo 0); db=$(( db+s )); }
    done
    local pct=0; (( total>0 )) && pct=$(( db*100/total ))
    local fill=$(( bw*pct/100 )) emp=$(( bw - bw*pct/100 ))
    local el; el=$(elapsed_since $t0); (( el<1 )) && el=1
    local spd=$(( db/el )) eta="inf"
    (( spd>0 && total>db )) && eta="$(( (total-db)/spd ))s"
    local bar="" empty=""
    for((i=0;i<fill;i++));  do bar+="█";   done
    for((i=0;i<emp;i++));   do empty+="░"; done
    printf "\r  [${G}%s${RST}${DIM}%s${RST}] ${Y}%3d%%${RST} ${C}%s${RST}@${M}%s/s${RST} ETA:${DIM}%s${RST}  " \
      "$bar" "$empty" "$pct" "$(human_size $db)" "$(human_size $spd)" "$eta"
    local alive=0
    for p in "${pids[@]}"; do kill -0 "$p" 2>/dev/null && (( alive++ )) || true; done
    (( alive==0 )) && break; sleep 0.25
  done
  printf "\r%*s\r" "$cols" ""
}

# ── Parallel chunk downloader — the core engine ───────────────────
# 1. HEAD  → Content-Length
# 2. Split → N byte-range curl jobs (all in background, capped)
# 3. Progress watcher polls /dev/shm chunk sizes
# 4. cat chunks → final file  (kernel handles the splice)
parallel_download() {
  local url=$1 dest=$2
  local tmpdir="${TMPBASE}/dl_${RANDOM}_$$"; mkdir -p "$tmpdir"
  local size; size=$(get_file_size "$url"); size="${size//[^0-9]/}"

  if [[ -z "$size" || "$size" -le 0 ]] || ! supports_ranges "$url"; then
    warn "No range support – single stream fallback"
    single_stream_download "$url" "$dest"; return $?
  fi

  local chunks=$PARALLEL_CHUNKS csz=$(( size / PARALLEL_CHUNKS ))
  if (( csz < CHUNK_MIN_SIZE )); then
    chunks=$(( size / CHUNK_MIN_SIZE )); (( chunks<1 )) && chunks=1
    csz=$(( size / chunks ))
  fi

  printf "\n  ${C}⚡ ${BOLD}%d parallel chunks × %s${RST}\n" "$chunks" "$(human_size $csz)"
  printf "  ${DIM}Total: %s  |  RAM tmp: %s${RST}\n\n" "$(human_size $size)" "$TMPBASE"

  local pids=() parts=() t0; t0=$(date +%s)
  for (( i=0; i<chunks; i++ )); do
    local s=$(( i * csz )) e
    (( i==chunks-1 )) && e=$(( size-1 )) || e=$(( s+csz-1 ))
    local part="${tmpdir}/part_$(printf '%04d' "$i")"; parts+=("$part")
    # Each chunk = one background curl with its own Range header
    curl "${CURL_OPTS[@]}" -H "Range: bytes=${s}-${e}" -o "$part" "$url" &
    pids+=($!)
    # Don't launch more than PARALLEL_CHUNKS at once
    while (( $(jobs -r | wc -l) >= PARALLEL_CHUNKS )); do sleep 0.05; done
  done

  _progress_watcher "$tmpdir" "$size" "${pids[@]}" &
  local wpid=$! failed=0
  for p in "${pids[@]}"; do wait "$p" || (( failed++ )) || true; done
  kill "$wpid" 2>/dev/null || true; wait "$wpid" 2>/dev/null || true

  if (( failed > 0 )); then
    warn "$failed chunk(s) failed – single stream retry"
    rm -rf "$tmpdir"; single_stream_download "$url" "$dest"; return $?
  fi

  local cols; cols=$(tput cols 2>/dev/null || echo 80)
  printf "\r  ${Y}⚙ Splicing %d chunks…${RST}%*s" "$chunks" "$cols" ""
  cat "${parts[@]}" > "$dest"   # kernel-level cat splice
  rm -rf "$tmpdir"
  local el; el=$(elapsed_since $t0); (( el<1 )) && el=1
  printf "\r%*s\r" "$cols" ""
  ok "$(human_size $size) in ${el}s — avg ${BOLD}$(human_size $(( size/el )))/s${RST}"
}

# ── Single stream (pv meter if available) ────────────────────────
single_stream_download() {
  local url=$1 dest=$2 t0; t0=$(date +%s)
  if has pv; then
    local sz; sz=$(get_file_size "$url"); sz="${sz//[^0-9]/}"
    [[ -n "$sz" && "$sz" -gt 0 ]] \
      && curl "${CURL_OPTS[@]}" "$url" | pv -s "$sz" -petra > "$dest" \
      || curl "${CURL_OPTS[@]}" "$url" | pv -petra > "$dest"
  elif has curl; then
    curl "${CURL_OPTS[@]}" --progress-bar -o "$dest" "$url"
  elif has wget; then
    wget "${WGET_OPTS[@]}" -O "$dest" "$url"
  else
    die "No download tool (need curl or wget)"
  fi
  local sz el; sz=$(stat -c%s "$dest" 2>/dev/null||echo 0)
  el=$(elapsed_since $t0); (( el<1 )) && el=1
  ok "$(human_size $sz) in ${el}s — avg ${BOLD}$(human_size $(( sz/el )))/s${RST}"
}

# ── aria2c ultra mode ─────────────────────────────────────────────
aria2c_download() {
  aria2c \
    --dir="$2" \
    --max-connection-per-server=16 \
    --split=16 \
    --min-split-size=1M \
    --max-concurrent-downloads=4 \
    --continue=true \
    --auto-file-renaming=false \
    --file-allocation=falloc \
    --disk-cache=64M \
    --seed-time=0 \
    --console-log-level=warn \
    --summary-interval=1 \
    --human-readable=true \
    "$1"
}

# ── Torrent / magnet ──────────────────────────────────────────────
is_torrent() {
  [[ "$1" == magnet:* ]]       && return 0
  [[ "${1,,}" == *.torrent* ]] && return 0
  return 1
}
download_torrent() {
  printf "\n  ${M}🧲 Torrent/Magnet detected${RST}\n"
  if   has aria2c;           then info "aria2c torrent";     aria2c_download "$1" "$2"
  elif has transmission-cli; then info "transmission-cli";   transmission-cli --download-dir "$2" --finish "" "$1"
  elif has rtorrent;         then info "rtorrent";            rtorrent -d "$2" -s "/tmp/bg_sess_$$" "$1"
  else die "No torrent client. Install: sudo apt install aria2"; fi
}

# ── Dispatcher ────────────────────────────────────────────────────
dispatch() {
  local url=$1 dest_dir=$2
  printf "\n  ${BOLD}${W}▶${RST}  ${DIM}%.78s${RST}\n" "$url"
  if is_torrent "$url"; then download_torrent "$url" "$dest_dir"; return; fi
  if has aria2c; then
    info "aria2c ultra mode (16 connections)"
    aria2c_download "$url" "$dest_dir"; return
  fi
  local fname; fname=$(get_filename_from_url "$url")
  info "Parallel bash chunks (${PARALLEL_CHUNKS}×) → ${BOLD}${fname}${RST}"
  parallel_download "$url" "${dest_dir}/${fname}"
}

# ── Queue runner ──────────────────────────────────────────────────
run_queue() {
  local urls=("$@") total=${#urls[@]}
  local rf="${TMPBASE}/results"; > "$rf"
  printf "\n  ${Y}🚀 Queue: ${BOLD}%d${RST}${Y} file(s)  max %d concurrent${RST}\n\n" \
    "$total" "$PARALLEL_FILES"
  local t0; t0=$(date +%s)
  for url in "${urls[@]}"; do
    while (( $(jobs -r | wc -l) >= PARALLEL_FILES )); do sleep 0.2; done
    ( dispatch "$url" "$DEST_DIR" \
        && printf "OK %s\n"   "$url" >> "$rf" \
        || printf "FAIL %s\n" "$url" >> "$rf" ) &
  done
  while (( $(jobs -r | wc -l) > 0 )); do sleep 0.3; done; wait
  local el; el=$(elapsed_since $t0)
  local comp=0 fail=0
  printf "\n${C}  ══════════════════════════════════════════\n"
  printf   "           📊  SUMMARY\n"
  printf   "  ══════════════════════════════════════════${RST}\n"
  while IFS= read -r line; do
    local st="${line%% *}" it="${line#* }"
    if [[ "$st" == "OK" ]]; then
      printf "  ${G}✓ OK  ${RST}${DIM}%.72s${RST}\n" "$it"; (( comp++ ))
    else
      printf "  ${R}✗ FAIL${RST}${DIM}%.72s${RST}\n" "$it"; (( fail++ ))
    fi
  done < "$rf"
  printf "\n  ${BOLD}${G}%d/%d${RST} done in ${Y}%ss${RST}  →  ${B}%s${RST}\n\n" \
    "$comp" "$total" "$el" "$DEST_DIR"
  (( fail > 0 )) && return 1 || return 0
}

# ── URL prompt ────────────────────────────────────────────────────
ask_urls() {
  printf "${Y}\n  📋 Enter URLs (HTTP/HTTPS/FTP / .torrent / magnet:)${RST}\n"
  printf "${DIM}  One per line. Empty line or 'done' to start.${RST}\n\n"
  URLS=(); local n=1
  while true; do
    read -rp "$(printf '  \e[94m[%d]\e[0m URL → ' "$n")" url
    if [[ -z "$url" || "${url,,}" == "done" ]]; then
      (( ${#URLS[@]} > 0 )) && break || { warn "Enter at least one URL."; continue; }
    fi
    URLS+=("$url"); ok "Added"; (( n++ ))
  done
}

# ── Entry ─────────────────────────────────────────────────────────
main() {
  banner; detect_tools
  has curl || has wget || die "curl or wget required."
  has aria2c || {
    warn "aria2c not found – parallel curl mode active."
    printf "  ${DIM}For max speed: sudo apt install aria2${RST}\n\n"
  }
  ask_directory
  (( $# > 0 )) && URLS=("$@") || ask_urls
  run_queue "${URLS[@]}"
}

main "$@"
